# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Spotify App Credentials (из Spotify Dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Redirect URI для Spotify OAuth
# Вариант 1 (локально): http://127.0.0.1:8000/callback
# Вариант 2 (с телефона): GitHub Pages relay — https://USERNAME.github.io/VKR/callback/
#   Добавьте оба варианта в Spotify Dashboard → Redirect URIs
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# Base URL сервера
BASE_URL=http://127.0.0.1:8000

# DeepSeek API Key (для генерации плейлистов через ИИ)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
